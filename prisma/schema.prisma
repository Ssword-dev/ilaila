generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma" // Required in v7
}

datasource db {
  provider = "postgresql"
}

model User {  
  // timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  id            String    @id
  userName      String?
  email         String    @unique
  passwordHash  String

  // "user" | "admin".
  role          String
}